# Copy this file to `.env` and adjust as needed. NEVER commit the real `.env`.

# Where the SQLite database file lives (relative to the backend/ dir).
DATABASE_URL=sqlite:///./penguwave.db

# CORS: the frontend dev server origin allowed to call this API.
CORS_ORIGIN=http://localhost:5173

# Seed user passwords. Defaults match the original starter so the demo works
# out-of-the-box; override them here for a more realistic setup.
ADMIN_PASSWORD=admin123
ANALYST_PASSWORD=pass456
VIEWER_PASSWORD=view789
